# Finals Buddy backend configuration — copy to .env and fill in.
# AI features require GROQ_API_KEY. Without it, AI-generation endpoints return
# a clear 503 error instead of fake data; everything else (CRUD, auth) still works.

# --- Database ---
# Default resolves relative to the process working directory.
# In Docker this lands in the mounted /srv/finals-buddy/data volume.
DATABASE_URL=sqlite:///./finals_buddy.db

# --- LLM provider ---
# GROQ_API_KEY_2 is an optional second key used as an automatic fallback when
# the primary key hits a rate limit.
GROQ_API_KEY=
GROQ_API_KEY_2=

# Listed in requirements but not used in the primary call path
OPENAI_API_KEY=

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- CORS ---
# Comma-separated origins of the deployed frontend (localhost is always allowed)
# CORS_ORIGINS=https://finals-buddy.vercel.app
CORS_ORIGINS=

# --- Admin dashboard ---
# Comma-separated email(s) allowed to access /api/admin/* (stats, logs,
# health check, Groq key rotation) at /admin in the frontend. Should be your
# own account's login email. Leave empty to disable the dashboard entirely.
# ADMIN_EMAILS=you@example.com
ADMIN_EMAILS=
